{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": {}
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem@latest", "${PWD}"],
      "env": {}
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@latest"],
      "env": {}
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "claude-context": {
      "command": "npx",
      "args": ["-y", "@dannyboy2042/claude-context-mcp@latest"],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "codebase-memory": {
      "type": "stdio",
      "command": "${HOME}/.local/bin/codebase-memory-mcp"
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "memory-service": {
      "command": "memory",
      "args": ["server"],
      "env": {
        "MCP_MEMORY_BASE_DIR": "${HOME}/.claude/memory-service",
        "MCP_EMBEDDING_MODEL": "all-mpnet-base-v2",
        "MCP_FORGETTING_ACCESS_THRESHOLD": "180",
        "MCP_CONSOLIDATION_ENABLED": "true"
      }
    }
  }
}
